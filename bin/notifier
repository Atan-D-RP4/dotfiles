#!/bin/bash

# systemd-timer-notify.sh - Create temporary systemd timers for notifications
# Usage: ./systemd-timer-notify.sh [OPTIONS]

set -euo pipefail

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Function to print colored output
print_info() { echo -e "${BLUE}[INFO]${NC} $1" >&2; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1" >&2; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1" >&2; }
print_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Function to normalize duration format for systemd
normalize_duration() {
	local input="$1"

	# systemd accepts formats like: 2h, 30min, 5s, 1d
	# or time spans like: 2h 30min 5s

	# If it already looks like systemd format (number + unit without space), pass through
	if [[ $input =~ ^[0-9]+(s|sec|second|seconds|m|min|minute|minutes|h|hr|hour|hours|d|day|days|w|week|weeks|M|month|months|y|year|years)$ ]]; then
		printf '%s' "$input"
		return 0
	fi

	# If it has spaces and looks like systemd format already, pass through
	if [[ $input =~ ^[0-9]+[[:space:]]+(s|sec|second|seconds|m|min|minute|minutes|h|hr|hour|hours|d|day|days|w|week|weeks|M|month|months|y|year|years)$ ]]; then
		printf '%s' "$input"
		return 0
	fi

	# Convert shorthand to systemd format (no space between number and unit)
	case "$input" in
	*s) printf '%s' "$input" ;;   # Already in format like 30s
	*m) printf '%s' "$input" ;;   # Already in format like 5m
	*h) printf '%s' "$input" ;;   # Already in format like 2h
	*d) printf '%s' "$input" ;;   # Already in format like 1d
	*w) printf '%s' "$input" ;;   # Already in format like 1w
	*) printf '%s' "${input}s" ;; # Plain number, add 's' for seconds
	esac
}

# Function to validate duration using GNU date
validate_duration() {
	local input="$1"
	local normalized

	normalized=$(normalize_duration "$input")

	# Try to parse with GNU date - if it works, it's valid
	if date -d "+${normalized}" +%s >/dev/null 2>&1; then
		printf '%s' "$normalized"
		return 0
	else
		return 1
	fi
}

# Function to check dependencies
check_dependencies() {
	local missing_deps=()

	command -v systemd-run >/dev/null 2>&1 || missing_deps+=("systemd")

	# Check for GNU date
	if ! date --version 2>/dev/null | grep -q "GNU"; then
		print_warning "GNU date not detected. Time calculations may not work properly."
	fi

	# Check for notification capabilities
	if ! command -v notify-send >/dev/null 2>&1 && ! command -v swaync-client >/dev/null 2>&1; then
		missing_deps+=("libnotify-bin or swaync")
	fi

	if [[ ${#missing_deps[@]} -gt 0 ]]; then
		print_error "Missing dependencies: ${missing_deps[*]}"
		[[ "${missing_deps[*]}" =~ systemd ]] && print_info "Install with: sudo apt install systemd"
		[[ "${missing_deps[*]}" =~ libnotify ]] && print_info "Install with: sudo apt install libnotify-bin"
		exit 1
	fi
}

# Function to send notification
send_notification() {
	local msg="$1"
	local title="${2:-Timer Alert}"

	# Use swaync if available, otherwise notify-send
	if command -v swaync-client >/dev/null 2>&1; then
		swaync-client -t "$title" -b "$msg"
	elif command -v notify-send >/dev/null 2>&1; then
		# Handle different user contexts
		if [[ -n "${SUDO_USER:-}" ]]; then
			sudo -u "$SUDO_USER" DISPLAY="${DISPLAY:-:0}" DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u "$SUDO_USER")/bus}" notify-send "$title" "$msg"
		else
			DISPLAY="${DISPLAY:-:0}" notify-send "$title" "$msg"
		fi
	fi

	# Play sound if available
	if command -v paplay >/dev/null 2>&1 && [[ -f "/usr/share/sounds/freedesktop/stereo/message-new-instant.oga" ]]; then
		paplay "/usr/share/sounds/freedesktop/stereo/message-new-instant.oga" 2>/dev/null || true
	fi

	# Also log for debugging
	echo "TIMER ALERT: $msg"
	logger -t "systemd-timer-notify" "$msg" 2>/dev/null || true
}

# Function to get timer duration via terminal
get_timer_duration() {
	local duration parsed

	while true; do
		read -r -p "Duration: " duration

		# Trim whitespace
		duration=$(echo "$duration" | xargs)

		[[ -z "$duration" ]] && {
			print_warning "Duration cannot be empty"
			continue
		}

		if parsed=$(validate_duration "$duration" 2>/dev/null); then
			printf '%s' "$parsed"
			return 0
		fi

		print_warning "Invalid time format. GNU date couldn't parse: $duration"
		print_info "Try: 30s, 5m, 2h, 1d, or '3 hours'"
	done
}

# Function to get notification message via terminal
get_notification_message() {
	local message

	read -r -p "Message: " message

	# Trim whitespace and return
	message=$(echo "$message" | xargs)
	printf '%s' "${message:-Timer notification}"
}

# Function to create notification script
create_notification_script() {
	local script_path="$1" message="$2" unit_name="$3"

	cat >"$script_path" <<'EOF'
#!/bin/bash
# Temporary notification script

set -euo pipefail

# Get display and user information
DISPLAY="${DISPLAY:-:0}"
export DISPLAY
REAL_USER="${SUDO_USER:-${USER}}"

# Function to send notification
send_notification() {
    local msg="$1" title="${2:-Timer Alert}"

    if command -v swaync-client >/dev/null 2>&1; then
        swaync-client -t "$title" -b "$msg"
    elif command -v notify-send >/dev/null 2>&1; then
        if [[ -n "${SUDO_USER:-}" ]]; then
            sudo -u "$REAL_USER" DISPLAY="$DISPLAY" DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u "$REAL_USER")/bus}" notify-send "$title" "$msg"
        else
            notify-send "$title" "$msg"
        fi
    fi

    if command -v paplay >/dev/null 2>&1 && [[ -f "/usr/share/sounds/freedesktop/stereo/message-new-instant.oga" ]]; then
        paplay "/usr/share/sounds/freedesktop/stereo/message-new-instant.oga" 2>/dev/null || true
    fi

    echo "TIMER ALERT: $msg"
    logger -t "systemd-timer-notify" "$msg" 2>/dev/null || true
}

# Function to cleanup
cleanup() {
    local unit="$1"
    systemctl --user stop "$unit" 2>/dev/null || true
    systemctl --user reset-failed "$unit" 2>/dev/null || true
    rm -f "$0"
}

# Main execution
MESSAGE="$1"
UNIT_NAME="$2"

send_notification "$MESSAGE"
cleanup "$UNIT_NAME"
EOF

	chmod +x "$script_path"
}

# Function to create and start timer
create_timer() {
	local duration="$1" message="$2"

	# Generate unique identifiers
	local timestamp random_id unit_name script_path
	timestamp=$(date +%s)
	random_id=$(head -c 8 /dev/urandom | tr -dc 'A-Za-z0-9' 2>/dev/null || echo "$")
	unit_name="timer-notify-${timestamp}-${random_id}"
	script_path="/tmp/${unit_name}.sh"

	# Create temporary script
	create_notification_script "$script_path" "$message" "$unit_name"

	# Show timer details
	echo
	print_info "Creating timer: $unit_name"
	print_info "Duration: $duration"

	local trigger_time
	if trigger_time=$(date -d "+${duration}" '+%c' 2>/dev/null); then
		print_info "Will trigger at: $trigger_time"
	else
		print_warning "Could not calculate trigger time"
	fi

	print_info "Message: $message"
	echo

	# Create and start the timer using systemd-run
	local systemd_output
	if systemd_output=$(systemd-run --user \
		--unit="$unit_name" \
		--on-active="$duration" \
		--timer-property=RemainAfterElapse=no \
		bash "$script_path" "$message" "$unit_name" 2>&1); then

		print_success "Timer created successfully!"
		print_info "Service name: $unit_name"
		print_info "Check status: systemctl --user status $unit_name"
		print_info "Cancel: systemctl --user stop $unit_name"
		return 0
	else
		print_error "Failed to create timer"
		print_error "systemd-run output: $systemd_output"
		rm -f "$script_path"
		return 1
	fi
}

# Function to list active timers
list_timers() {
	print_info "Active notification timers:"
	echo
	if ! systemctl --user list-timers --all 2>/dev/null | grep -q "timer-notify-"; then
		print_info "No active notification timers found"
	else
		systemctl --user list-timers --all | grep "timer-notify-" || true
	fi
}

# Function to cleanup old timers
cleanup_old_timers() {
	print_info "Cleaning up old notification timers..."

	local cleaned=0
	local units
	units=$(systemctl --user list-units --state=failed,inactive 2>/dev/null | grep "timer-notify-" | awk '{print $1}' || true)

	while IFS= read -r unit; do
		if [[ -n "$unit" && $unit =~ timer-notify- ]]; then
			print_info "Stopping $unit"
			systemctl --user stop "$unit" 2>/dev/null || true
			systemctl --user reset-failed "$unit" 2>/dev/null || true
			((cleaned++))
		fi
	done <<<"$units"

	print_success "Cleaned up $cleaned old timers"
}

# Function to show help
show_help() {
	cat >&2 <<EOF
Usage: $0 [OPTIONS]

Options:
  --list, -l      List active notification timers
  --cleanup, -c   Cleanup old/failed timers
  --help, -h      Show this help message

Time format examples:
  30s or 30       30 seconds
  5m              5 minutes
  2h              2 hours
  1d              1 day
  1w              1 week

You can also use natural language that GNU date understands:
  "3 hours"       3 hours from now
  "90 minutes"    90 minutes from now
  "tomorrow"      Tomorrow at same time
  "next week"     One week from now

Features:
  - Simple terminal interface
  - Automatic cleanup of timer scripts
  - Integration with swaync and libnotify
  - Uses GNU date for accurate time calculations
EOF
}

# Main function
main() {
	# Handle command line arguments
	case "${1:-}" in
	--list | -l)
		list_timers
		exit 0
		;;
	--cleanup | -c)
		cleanup_old_timers
		exit 0
		;;
	--help | -h)
		show_help
		exit 0
		;;
	esac

	print_info "systemd Timer Notification Script"

	# Check dependencies
	check_dependencies

	# Show instructions
	echo >&2
	print_info "Enter timer duration"
	print_info "Examples: 30s, 5m, 2h, 1d, '3 hours', '90 minutes'"
	echo >&2

	# Get inputs
	local duration message

	duration=$(get_timer_duration)
	message=$(get_notification_message)

	# Create and start timer
	create_timer "$duration" "$message"
}

# Handle Ctrl+C gracefully
trap 'echo; print_info "Operation cancelled"; exit 130' INT

# Run main function
main "$@"

# vim: set ft=bash
