	"command": {
		"test": {
			"template": "Run the project's test suite and report any failures with suggested fixes. Look for test configuration (pytest.ini, Cargo.toml, package.json, Makefile) to determine the correct test command.",
			"description": "Run full test suite",
			"agent": "build"
		},
		"test-fast": {
			"template": "Run a quick subset of tests for fast validation. Use --fast flags or equivalent for the project's test framework.",
			"description": "Run tests skipping slow ones"
		},
		"test-suite": {
			"template": "Run tests for the specific module or path: $ARGUMENTS\n\nIf no module is specified, run the full test suite.",
			"description": "Run specific test suite"
		},
		"review-docs": {
			"template": "Review documentation file $ARGUMENTS for code synchronization and standards compliance\n\nIf no file is specified, review all documentation files in the project.",
			"description": "Review documentation",
			"agent": "doc-reviewer"
		},
		"check-yagni": {
			"template": "Analyze the following target for YAGNI violations and over-engineering: $ARGUMENTS\n\nIf no target is specified, analyze the current working directory and all source files within it.",
			"description": "Check for scope creep",
			"agent": "yagni-checker"
		},
		"review": {
			"template": "Review implementation for gaps, TODOs, orphaned code, and missing integrations.\n\nTarget: $ARGUMENTS\n\nIf no target specified, review staged/uncommitted changes.\nIf --since <branch> specified, review changes since that branch.\nIf --spec <path> specified, also validate against acceptance criteria.",
			"description": "Review implementation completeness",
			"agent": "implementation-reviewer"
		},
		"fix-lint": {
			"template": "Fix linting and formatting violations in staged files. Detect the project's linter/formatter from config files (pyproject.toml, .eslintrc, rustfmt.toml, etc.)",
			"description": "Fix linting issues",
			"agent": "quick-fix"
		},
		"create-worktree": {
			"template": "Create a git worktree for feature: $ARGUMENTS. Determine the project name from the current directory and run: git worktree add ../<project>-$ARGUMENTS -b $ARGUMENTS\n\nIf no feature name is specified, prompt for a feature name.",
			"description": "Create git worktree for feature development"
		}
	},
	"permission": {
		"bash": {
			"git push": "ask",
			"git push --force": "deny",
			"rm -rf*": "deny",
			"rm -fr*": "deny"
		}
	},
	"tools": {
		"webfetch": true,
		"ast-grep": true
	},
	"mcp": {
		"deepwiki": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.deepwiki.com/sse"
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		}
	},
	"lsp": {
		"pyrefly": {
			"command": [
				"uvx",
				"pyrefly",
				"lsp"
			],
			"extensions": [
				".py",
				".pyi"
			]
		}
	},
	"formatter": {
		"ruff": {
			"command": [
				"uvx",
				"ruff",
				"format",
				"$FILE"
			],
			"extensions": [
				".py"
			]
		}
	}
}
