{
	"$schema": "https://opencode.ai/config.json",
	"plugin": [
		"@tarquinen/opencode-dcp@latest"
		// "opencode-elf@latest"
	],
	"instructions": [
		"AGENTS.md",
		"CONTRIBUTING.md",
		"docs/principles/yagni-kiss.md",
		"docs/principles/documentation-standards.md",
		"docs/principles/documentation-content-guidelines.md"
	],
	"agent": {
		"build": {
			"mode": "primary",
			"description": "Full development with all tools enabled",
			"model": "github-copilot/claude-opus-4.5",
			"temperature": 0.3,
			"tools": {
				"read": true,
				"write": true,
				"edit": true,
				"bash": true,
				"glob": true,
				"grep": true,
				"list": true,
				"patch": true,
				"webfetch": true,
				"todoread": true,
				"todowrite": true,
				"ast-grep": true
			}
		},
		"plan": {
			"mode": "primary",
			"description": "Analysis and planning without making changes",
			"model": "github-copilot/claude-sonnet-4.5",
			"temperature": 0.1,
			"tools": {
				"read": true,
				"write": false,
				"edit": false,
				"bash": true,
				"glob": true,
				"grep": true,
				"list": true,
				"patch": false,
				"webfetch": true,
				"todoread": true,
				"todowrite": true,
				"ast-grep": true
			}
		},
		"general": {
			"disabled": true,
			"mode": "primary",
			"description": "General assistant for code changes and questions",
			"prompt": "{file:agent/general.md}",
			"model": "opencode/big-pickle",
			"temperature": 0.3,
			"tools": {
				"read": true,
				"write": true,
				"edit": true,
				"bash": true,
				"glob": true,
				"grep": true,
				"list": true,
				"patch": true,
				"webfetch": true,
				"todoread": true,
				"todowrite": true,
				"ast-grep": true
			}
		},
		"brief-agent": {
			"mode": "primary",
			"description": "Builds project briefs by gathering context from codebase and user",
			"prompt": "{file:agent/brief-agent.md}",
			"temperature": 0.3,
			"tools": {
				"read": true,
				"write": true,
				"edit": false,
				"bash": false,
				"glob": true,
