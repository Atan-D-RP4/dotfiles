# 	export RAYON_NUM_THREADS=1 # required so we can build in environments with _many_ threads
# 	cargo test --all --exclude niri-visual-tests --frozen
# }

package() {
	cd "$pkgname"
	install -Dm755 "target/release/${pkgname%-custom}" -t "${pkgdir}/usr/bin/"
	install -Dm755 "resources/${pkgname%-custom}-session" -t "${pkgdir}/usr/bin/"
	install -Dm644 resources/default-config.kdl -t "${pkgdir}/usr/share/doc/niri"
	install -Dm644 "resources/${pkgname%-custom}.desktop" -t "${pkgdir}/usr/share/wayland-sessions/"
	install -Dm644 "resources/${pkgname%-custom}-portals.conf" -t "${pkgdir}/usr/share/xdg-desktop-portal/"
	install -Dm644 "resources/${pkgname%-custom}"{.service,-shutdown.target} -t "${pkgdir}/usr/lib/systemd/user/"
	# shell auto-completions
	install -vDm 644 fish-completions "${pkgdir}/usr/share/fish/vendor_completions.d/niri.fish"
	strip -s "${pkgdir}/usr/bin/niri"

}
