(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold yes
  sequence-input-mode hidden-delay-type
  override-release-on-activation yes
  delegate-to-first-layer yes
  alias-to-trigger-on-load 2hrw
)

(defvar
  tap-time   150
  hold-time  200
  chord-time 80
)

(defoverrides
  (ralt \) (tab)
  (ralt ;) (esc)
)

(defchordsv2
  ([ \) (macro tab)     $chord-time all-released ()
  (j k) (macro esc esc) $chord-time all-released ()
)

(defalias
  lay    (layer-toggle layers)

  num   (tap-hold-release $tap-time $hold-time ' (layer-toggle numbers))

  grl   (tap-hold-release $tap-time $hold-time grv @lay)

  a-lmt (tap-hold       $tap-time       $hold-time         a              lmet)
  s-lal (tap-hold       $tap-time       $hold-time         s              lalt)
  d-lct (tap-hold       $tap-time       $hold-time         d              lctl)
  f-lsh (tap-hold       $tap-time       $hold-time         f              lsft)

  j-rmt (tap-hold       $tap-time       $hold-time         j              rsft)
  k-rct (tap-hold       $tap-time       $hold-time         k              rctl)
  l-ral (tap-hold       $tap-time       $hold-time         l              ralt)
  ;-rsh (tap-hold       $tap-time       $hold-time         ;              rmet)

  ret   (tap-hold-press $tap-time       $hold-time         ret            rctl)
  cap   (tap-hold-press $tap-time       $hold-time         esc            lctl)
  esc   caps
)

(defsrc
  esc     f1      f2      f3      f4      f5      f6      f7      f8      f9      f10     f11     f12
  grv     1       2       3       4       5       6       7       8       9       0       -       =       bspc
  tab     q       w       e       r       t       y       u       i       o       p       [       ]       \
  caps    a       s       d       f       g       h       j       k       l       ;       '       ret
  lsft    z       x       c       v       b       n       m       ,       .       /       rsft    up
  lctl    lmet    lalt                    spc                     ralt    rmet    rctl    left    down    right
)

(deflayer base-layer
  @esc    _       _       _       _       _       _       _       _       _       _       _       _
  @grl    _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _
  @cap    _       _       _       _       _       _       _       _       _       _       @num    @ret
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _                       _                       _       _       _       _       _       _
)

(deflayer homerow-kbd
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _
  @cap    @a-lmt  @s-lal  @d-lct  @f-lsh  _       _       @j-rmt  @k-rct  @l-ral  @;-rsh  @num    @ret
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _                       _                       _       _       _       _       _       _
)

(deflayer numbers
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _
  _       1       2       3       _       _       _       _       _       _       _       _       _       _
  _       4       5       6       _       _       _       _       _       _       _       _       _
  _       7       8       9       _       _       _       _       _       _       _       _       _
  _       _       0                       _                       _       _       _       _       _       _
)

(deflayer layers
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       @1bas   @2hrw   sldr    lrld    @5clk    _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _                       _                       _       _       _       _       _       _
)

(defalias
  1bas   (multi
    (layer-switch base-layer)
    (push-msg "layer:base-layer:activated")
  )

  2hrw   (multi
    (layer-switch homerow-kbd)
    (push-msg "layer:homerow-kbd:activated")
  )
)

;; ============================================================================
;; Auto-clicker (cross-platform, pure kanata implementation)
;; ============================================================================
;; Toggle with a key to start/stop auto-clicking.
;; Uses macro-repeat which clicks while the virtual key is held.

(defvirtualkeys
  ;; State tracker for auto-clicker
  click-active XX
  ;; The actual clicking action - repeats left click every 100ms while held
  click-action (macro-repeat 100 mltp)
)

(defalias
  ;; Toggle auto-clicker on/off, with feedback messages
  5clk (switch
    ((input virtual click-active))
      (multi
        (on-press release-virtualkey click-active)
        (on-press release-virtualkey click-action)
        (push-msg "Auto-clicker deactivated")
      )
      break
    ()
      (multi
        (on-press press-virtualkey click-active)
        (on-press press-virtualkey click-action)
        (push-msg "Auto-clicker activated")
      )
      break
  )
)

(deftemplate abbrev (vk-name input-keys output)
  (deffakekeys $vk-name $output)
  (defseq $vk-name $input-keys)
)

